  "cta": "<style>\n  :root { --accent: {{ACCENT_COLOR}}; }\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n  html, body { width: 960px; height: 540px; overflow: hidden;\n    font-family: 'Pretendard', -apple-system, 'Malgun Gothic', sans-serif; }\n</style>\n<style>\n        body {\n            background-color: #080e1c;\n            color: #e0e5f9;\n            font-family: 'Manrope', sans-serif;\n            margin: 0;\n            overflow: hidden;\n        }\n        .slide-canvas {\n            aspect-ratio: 16 / 9;\n            width: 100%;\n            max-width: 1600px;\n            margin: 0 auto;\n            position: relative;\n            background-color: #0c1322; /* surface-container-low */\n            display: flex;\n            flex-direction: column;\n            overflow: hidden;\n        }\n        .slide-deco-circle {\n            position: absolute;\n            top: -15%;\n            right: -10%;\n            width: 60%;\n            height: 100%;\n            border-radius: 9999px;\n            background: radial-gradient(circle, rgba(186, 158, 255, 0.05) 0%, rgba(8, 14, 28, 0) 70%);\n            pointer-events: none;\n        }\n        .slide-accent-bar {\n            position: absolute;\n            left: 0;\n            top: 0;\n            bottom: 0;\n            width: 4px;\n            background-color: var(--accent, #7c5cf6);\n        }\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n    </style>\n\n<!-- Main 16:9 Presentation Canvas -->\n<main class=\"slide-canvas shadow-2xl\">\n<!-- TOP NAV BAR (Shared Component Anchor) -->\n<nav class=\"bg-[#0c1322] flex justify-between items-center w-full px-12 py-6 max-w-full z-10\">\n<div class=\"text-lg font-extrabold tracking-tighter text-[#e0e5f9]\">MIDNIGHT MONOLITH</div>\n<div class=\"hidden md:flex gap-8 items-center\">\n<a class=\"font-manrope font-medium text-[10px] tracking-[0.2em] uppercase text-[#a5abbe] hover:text-[var(--accent, #7c5cf6)] transition-colors\" href=\"#\">Executive Summary</a>\n<a class=\"font-manrope font-medium text-[10px] tracking-[0.2em] uppercase text-[#a5abbe] hover:text-[var(--accent, #7c5cf6)] transition-colors\" href=\"#\">Market Analysis</a>\n<a class=\"font-manrope font-medium text-[10px] tracking-[0.2em] uppercase text-[#a5abbe] hover:text-[var(--accent, #7c5cf6)] transition-colors\" href=\"#\">Strategic Pillars</a>\n<a class=\"font-manrope font-medium text-[10px] tracking-[0.2em] uppercase text-[#a5abbe] hover:text-[var(--accent, #7c5cf6)] transition-colors\" href=\"#\">Financial Outlook</a>\n<a class=\"font-manrope font-bold tracking-tight uppercase text-xs text-[var(--accent, #7c5cf6)] border-b-2 border-[var(--accent, #7c5cf6)] pb-1\" href=\"#\">Appendix</a>\n</div>\n<div class=\"flex items-center text-[var(--accent, #7c5cf6)]\">\n<span class=\"material-symbols-outlined\" data-icon=\"more_vert\">more_vert</span>\n</div>\n</nav>\n<!-- Slide Background Elements -->\n<div class=\"slide-accent-bar\"></div>\n<div class=\"slide-deco-circle\"></div>\n<!-- CONTENT AREA (Centered CTA) -->\n<section class=\"flex-grow flex flex-col items-center justify-center text-center relative z-10 px-6\">\n<div class=\"max-w-3xl flex flex-col items-center\">\n<!-- Eyebrow -->\n<p class=\"font-manrope font-bold text-sm tracking-[0.4em] text-primary mb-6 uppercase\">PROJECT COMPLETE</p>\n<!-- Headline -->\n<h1 class=\"font-headline font-extrabold text-5xl md:text-7xl lg:text-8xl text-on-surface leading-[1.1] tracking-tighter mb-8 whitespace-pre-line\">\n                    THE NEW\n                    ERA BEGINS\n                </h1>\n<!-- Subtitle -->\n<p class=\"font-body text-lg md:text-xl text-on-surface-variant font-light tracking-wide max-w-lg mb-12\">\n                    Join us in redefining the structural future.\n                </p>\n<!-- Horizontal Accent Line -->\n<div class=\"w-24 h-1 bg-primary rounded-full mb-16\"></div>\n<!-- Action Button -->\n<button class=\"bg-gradient-to-r from-primary to-primary-dim text-on-primary font-bold px-10 py-4 rounded-DEFAULT hover:scale-105 transition-transform duration-300 uppercase tracking-widest text-xs\">\n                    Get Started\n                </button>\n</div>\n</section>\n<!-- FOOTER (Shared Component Anchor) -->\n<footer class=\"fixed bottom-0 w-full flex justify-between items-center px-12 py-8 z-20 pointer-events-none\">\n<div class=\"font-manrope font-medium text-[10px] tracking-[0.2em] uppercase text-[#a5abbe] opacity-80 pointer-events-auto\">\n                © 2024 MONOLITH STRATEGY GROUP • CONFIDENTIAL\n            </div>\n<div class=\"flex gap-4 pointer-events-auto\">\n<span class=\"font-manrope font-medium text-[10px] tracking-[0.2em] uppercase text-[#e0e5f9] transition-opacity\">SLIDE 01</span>\n</div>\n</footer>\n<!-- Glassmorphic Informational Card (Asymmetric Layout Element) -->\n<div class=\"absolute bottom-20 right-12 w-64 p-6 bg-surface-bright/40 backdrop-blur-xl rounded-lg border border-outline-variant/20 hidden lg:block z-10\">\n<div class=\"flex items-center gap-3 mb-4\">\n<span class=\"material-symbols-outlined text-primary\" data-icon=\"verified\">verified</span>\n<span class=\"text-[10px] font-bold tracking-[0.2em] text-on-surface uppercase\">Phase IV Finalized</span>\n</div>\n<p class=\"text-[11px] text-on-surface-variant leading-relaxed\">\n                All milestones for the current fiscal quarter have been met. Transitioning to active deployment phase.\n            </p>\n</div>\n</main>\n"
